# Telegram
TELEGRAM_BOT_TOKEN=
# Optional allow-list. Leave empty during local testing, then lock it down.
# Example: TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=

# LLM provider: stub, anthropic, or deepseek
LLM_PROVIDER=stub
LLM_MODEL=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# X recent search API. Leave empty to disable X fetching.
X_BEARER_TOKEN=
X_QUERY_TEMPLATE="{topic}" lang:en -is:retweet -is:reply

# Comma-separated feed specs. Use either URL or Name|URL.
# Placeholders are supported: {topic}, {topic_q}
# Example: RSS_FEEDS=Bloomberg Markets|https://feeds.bloomberg.com/markets/news.rss,Yahoo SPY|https://finance.yahoo.com/rss/headline?s=SPY
RSS_FEEDS=

# Extra Yahoo Finance ticker RSS feeds.
YAHOO_FINANCE_SYMBOLS=SPY,QQQ,BTC-USD,ETH-USD

# Bot behavior
NEWS_LOOKBACK_HOURS=24
MAX_ITEMS_PER_PROVIDER=40
MIN_RELEVANCE_SCORE=0.30
TRACK_INTERVAL_MINUTES=30
DATA_DIR=.data
